generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("STUDENT") // STUDENT, ADMIN
  level     String   @default("BEGINNER") // BEGINNER, INTERMEDIATE, ADVANCED
  xp        Int      @default(0)
  streak    Int      @default(0)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  progress  Progress[]
  flashcardProgress FlashcardProgress[]
  achievements      UserAchievement[]
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  description String
  content     String
  level       String   // BEGINNER, INTERMEDIATE, ADVANCED
  category    String   // GRAMMAR, VOCABULARY, READING
  exercises   Exercise[]
  progress    Progress[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exercise {
  id            String   @id @default(uuid())
  lessonId      String
  lesson        Lesson   @relation(fields: [lessonId], references: [id])
  type          String   // MULTIPLE_CHOICE, FILL_BLANKS, TRANSLATE
  question      String
  options       String?  // JSON stringified for multiple choice
  correctAnswer String
  explanation   String?
}

model Progress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  completed Boolean  @default(false)
  score     Int      @default(0)
  updatedAt DateTime @updatedAt
  @@unique([userId, lessonId])
}

model Vocabulary {
  id          String   @id @default(uuid())
  word        String   @unique
  meaning     String
  translation String?
  synonyms    String?
  example     String?
  level       String   // BEGINNER, INTERMEDIATE, ADVANCED
  category    String   // NOUN, VERB, IDIOM, PHRASAL_VERB
  flashcardProgress FlashcardProgress[]
  createdAt   DateTime @default(now())
}

model FlashcardProgress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  vocabId     String
  vocabulary  Vocabulary @relation(fields: [vocabId], references: [id])
  mastery     Float    @default(0) // 0 to 1
  interval    Int      @default(0) // days
  nextReview  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([userId, vocabId])
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String
  category    String   // STREAK, XP, LESSONS
  requirement Int
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime    @default(now())
  @@unique([userId, achievementId])
}
